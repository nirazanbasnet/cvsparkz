# ── Supabase ───────────────────────────────────────────────
# Public (web, client-safe)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (worker + privileged server actions). NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── AI (Anthropic Claude — primary) ────────────────────────
ANTHROPIC_API_KEY=
# Model routing (read current IDs from the claude-api skill at impl time)
MODEL_CHEAP=claude-haiku-4-5-20251001
MODEL_BALANCED=claude-sonnet-4-6
MODEL_PREMIUM=claude-opus-4-8

# Optional fallback provider
GEMINI_API_KEY=

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_POWER=

# ── Object storage (Supabase Storage bucket names) ─────────
STORAGE_BUCKET_DOCS=documents
STORAGE_BUCKET_EXPORTS=exports

# ── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Job scanner browser (custom careers pages) ─────────────
# Custom (non-ATS) careers pages are JS-rendered, so the scanner drives a
# headless browser. Locally this uses Playwright's bundled Chromium — no config.
#
# On Vercel, set BROWSER_WS_ENDPOINT to a HOSTED browser (Browserless,
# Browserbase, Bright Data…) and the scanner connects over CDP — nothing
# Chromium ships in the function, so it deploys cleanly. Examples:
#   BROWSER_WS_ENDPOINT=wss://production-sfo.browserless.io?token=YOUR_TOKEN
#   BROWSER_WS_ENDPOINT=wss://connect.browserbase.com?apiKey=YOUR_KEY
# Leave empty to fall back to @sparticuz/chromium (needs Vercel Pro: ≥1GB memory
# + maxDuration, configured in web/vercel.json).
BROWSER_WS_ENDPOINT=
