# Local Supabase external-auth credentials, read by config.toml via env(...).
# Copy to `supabase/.env` (gitignored) and fill in real values, then:
#   set -a; source supabase/.env; set +a; supabase start
# See docs/GOOGLE_AUTH.md for where to get these.
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
